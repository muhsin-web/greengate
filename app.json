{
  "expo": {
    "name": "greengate",
    "slug": "greengate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-logo/greengate-logo.png",
    "scheme": "greengate",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/app-logo/greengate-logo.png",
      "bundleIdentifier": "com.falconpay.greengate"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/app-logo/greengate-logo.png",
        "backgroundImage": "./assets/images/app-logo/greengate-logo.png",
        "monochromeImage": "./assets/images/app-logo/greengate-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.falconpay.greengate"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/app-logo/greengate-logo.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/BricolageGrotesque-Light.ttf",
            "./assets/fonts/BricolageGrotesque-ExtraLight.ttf",
            "./assets/fonts/BricolageGrotesque-Regular.ttf",
            "./assets/fonts/BricolageGrotesque-Medium.ttf",
            "./assets/fonts/BricolageGrotesque-SemiBold.ttf",
            "./assets/fonts/BricolageGrotesque-Bold.ttf",
            "./assets/fonts/BricolageGrotesque-ExtraBold.ttf"
          ]
        }
      ],
      "expo-image",
      [
        "expo-status-bar",
        {
          "hidden": false,
          "style": "light"
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Greengate to use Face ID."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
