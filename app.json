{
  "expo": {
    "name": "greengate",
    "slug": "greengate",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/app-logo/greengate-logo.png",
    "scheme": "greengate",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/app-logo/greengate-logo.png",
      "bundleIdentifier": "com.falconpay.greengate",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Greengate accesses your photos to let you upload a profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/app-logo/greengate-logo.png",
        "backgroundImage": "./assets/images/app-logo/greengate-logo.png",
        "monochromeImage": "./assets/images/app-logo/greengate-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.falconpay.greengate",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/app-logo/greengate-logo.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/BricolageGrotesque-Light.ttf",
            "./assets/fonts/BricolageGrotesque-ExtraLight.ttf",
            "./assets/fonts/BricolageGrotesque-Regular.ttf",
            "./assets/fonts/BricolageGrotesque-Medium.ttf",
            "./assets/fonts/BricolageGrotesque-SemiBold.ttf",
            "./assets/fonts/BricolageGrotesque-Bold.ttf",
            "./assets/fonts/BricolageGrotesque-ExtraBold.ttf"
          ]
        }
      ],
      "expo-image",
      [
        "expo-status-bar",
        {
          "hidden": false,
          "style": "dark"
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Greengate to use Face ID."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Greengate to access your camera",
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends.",
          "colors": {
            "cropToolbarColor": "#000000"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#000000"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "expo-status-bar": {
        "style": "dark",
        "hidden": false
      },
      "eas": {
        "projectId": "0ddc396d-e69e-4241-952c-c394eab96603"
      }
    }
  }
}
